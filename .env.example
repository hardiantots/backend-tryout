DATABASE_URL="postgresql://postgres:postgres@localhost:5432/snbt_db?schema=public"
JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"
PORT=3001
APP_ORIGINS="http://localhost:5173"
# TRUST_PROXY supports boolean or numeric hop count. For CloudFront -> ALB -> NestJS, use 2.
TRUST_PROXY=2

# Primary OpenRouter-style variables (compatible with reference route)
OPENROUTER_API_KEY="your-openrouter-api-key"
AI_MODEL="google/gemini-2.5-flash-lite"

# Backward-compatible aliases used in this backend
LLM_API_KEY="your-openrouter-api-key"
LLM_MODEL="openai/gpt-oss-120b:free"
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_CHAT_ENDPOINT="/chat/completions"
LLM_TIMEOUT_MS=15000
LLM_APP_URL="https://your-app-domain.com"
LLM_APP_TITLE="Try Out SNBT 2026"
NEXT_PUBLIC_SITE_URL="http://localhost:5173"

# Password reset email settings
PASSWORD_RESET_BASE_URL="http://localhost:5173/reset-password"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""

# AWS S3 for direct question image upload
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="your-snbt-question-images-bucket"
# Optional CDN/public base URL, e.g. CloudFront domain
AWS_S3_PUBLIC_BASE_URL=""
